# 개발: 미설정 시 콘솔 경고 후 기본 admin / admin (운영에 쓰지 마세요)
# 운영(NODE_ENV=production): 필수 — 12자 이상 강한 비밀번호
CARD_MONITOR_ADMIN_PASSWORD=

# 운영(NODE_ENV=production): 필수 — openssl rand -base64 32 등
SESSION_SECRET=

# 선택 — 기본 admin
# CARD_MONITOR_ADMIN_USER=admin

# 브라우저 출처 허용(쉼표 구분). 운영에서는 http://localhost:3001 등 실제 출처만 나열
# ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# 리버스 프록시(nginx 등) 뒤에서 올바른 클라이언트 IP·secure 쿠키를 쓰려면 1
# TRUST_PROXY=1

# ---- 데이터 저장소 (기본: SQLite, server/data/app.db) ----
# Firebase Firestore 사용 시 아래 중 하나를 설정하고 DATABASE_BACKEND 를 firestore 로 두세요.
# DATABASE_BACKEND=firestore
# 서비스 계정 JSON 파일 경로(권장: CI/로컬)
# GOOGLE_APPLICATION_CREDENTIALS=C:\secrets\firebase-adminsdk.json
# 또는 JSON 전체를 한 줄 문자열로(이스케이프 주의; Windows PowerShell은 여러 줄 파일 경로 권장)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GCP(Cloud Run 등)에 올리면 위 없이도 application default credentials 로 동작할 수 있습니다.
