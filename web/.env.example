# 로컬: docker compose -f docker-compose.yml up -d 후 아래 URL 사용
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/card_compliance?schema=public"

# Vercel·Neon 등 프로덕션
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/db?sslmode=require"

NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# design-preview.html 로그인 (/api/cm/auth) — 비우면 개발에서만 기본 admin/admin (운영에서는 반드시 설정)
# CARD_MONITOR_ADMIN_PASSWORD="strong-password-here"
# CARD_MONITOR_ADMIN_USER=admin

# 로컬
NEXTAUTH_URL="http://localhost:3000"
# Vercel 프로덕션 예: https://sbsmccard.vercel.app
# Optional: enable OpenAI instead of mock scoring
# OPENAI_API_KEY="sk-..."
