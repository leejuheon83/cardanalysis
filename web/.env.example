# 로컬: docker compose -f docker-compose.yml up -d 후 아래 URL 사용
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/card_compliance?schema=public"

# Vercel·Neon 등 프로덕션
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/db?sslmode=require"

NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# 로컬
NEXTAUTH_URL="http://localhost:3000"
# Vercel 배포 후 실제 도메인으로 변경 (예: https://your-app.vercel.app)
# Optional: enable OpenAI instead of mock scoring
# OPENAI_API_KEY="sk-..."
